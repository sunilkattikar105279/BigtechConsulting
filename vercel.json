{
  "version": 2,
  "name": "bigtechconsulting",
  "public": true,
  "buildCommand": null,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/services", "destination": "/#services" },
    { "source": "/verticals", "destination": "/#verticals" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/assessment", "destination": "/tools/ai-maturity-assessment", "permanent": false },
    { "source": "/maturity", "destination": "/tools/ai-maturity-assessment", "permanent": false },
    { "source": "/sixxab", "destination": "https://startupsinabox.com", "permanent": false },
    { "source": "/launch", "destination": "/launch-plan", "permanent": false }
  ]
}
