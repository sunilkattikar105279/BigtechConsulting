{
  "version": 2,
  "routes": [
    { "src": "^/$",                                "dest": "/index.html" },
    { "src": "^/blog$",                            "dest": "/blog/index.html" },
    { "src": "^/blog/([^/]+)$",                    "dest": "/blog/$1.html" },
    { "src": "^/services/([^/]+)$",                "dest": "/services/$1.html" },
    { "src": "^/verticals/([^/]+)$",               "dest": "/verticals/$1.html" },
    { "src": "^/tools/([^/]+)$",                   "dest": "/tools/$1.html" },
    { "src": "^/assessment$",                      "dest": "/tools/ai-maturity-assessment.html" },
    { "src": "^/(.*)\\.html$",                     "dest": "/$1.html" },
    { "src": "^/(.*\\.(css|js|ico|png|jpg|svg|txt|xml))$", "dest": "/$1" },
    { "src": "^/(.*)$",                            "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
